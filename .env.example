# Токен бота-пульта (создать через @BotFather)
REPLYTG_BOT_TOKEN=123456:ABC...
# Твой Telegram user id (карточки шлются только сюда, остальные игнорируются)
REPLYTG_OWNER_ID=123456789
# Путь к базе telegram-business-bridge
REPLYTG_BRIDGE_DB_PATH=/home/user/telegram-business-bridge/data/bridge.db
# OpenAI-совместимый LLM
REPLYTG_LLM_BASE_URL=https://example.com/v1
REPLYTG_LLM_API_KEY=sk-...
REPLYTG_LLM_MODEL=mimo-v2.5-pro
# Каданс (секунды): окно волны / тишина после использования / повтор карточки
REPLYTG_WAVE_WINDOW_SEC=600
REPLYTG_USED_SILENCE_SEC=3600
REPLYTG_REPEAT_AFTER_SEC=7200
# Чаты, где подсказки не нужны (JSON-список chat_id)
REPLYTG_CHAT_BLOCKLIST=[]
# Максимальная длина одного варианта ответа (100–1500)
REPLYTG_MAX_VARIANT_LEN=1000
